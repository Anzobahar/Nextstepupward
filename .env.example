# =====================================================================
#  Copy this file to `.env` for LOCAL development (`npm run dev`).
#  On VERCEL, set these same keys in Project → Settings → Environment
#  Variables (do NOT commit a real .env).
# =====================================================================

# ---- Stripe keys (https://dashboard.stripe.com/apikeys) ----
# Use TEST keys (sk_test_...) while developing.
# (test keys start with sk_test_, live keys with sk_live_)
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...). From `stripe listen` locally, or from the
# Stripe dashboard when you add the webhook endpoint in production.
# If blank, webhook events are accepted WITHOUT signature checks (dev only).
STRIPE_WEBHOOK_SECRET=

# Public URL of the site. On Vercel this is optional — success/cancel URLs are
# derived from the request host automatically. Set it to your custom domain in
# production to be explicit, e.g. https://nextstepupward.com
SITE_URL=http://localhost:3000

# Only for the LOCAL Express server, and only if the front-end is on a different
# origin than the API. Leave blank when the server serves the site.
ALLOWED_ORIGIN=

# Port for the local Express server.
PORT=3000

# ---- Optional: pre-created Stripe Price IDs (recommended for production) ----
# Create Products/Prices in the Stripe dashboard and paste the price_... ids.
# If set, these override the inline amounts in lib/catalog.js.
PRICE_SINGLE=
PRICE_PACKAGE5=
PRICE_MEMBERSHIP=
PRICE_COURSE_SLEEP=
PRICE_COURSE_FOCUS=
PRICE_COURSE_STRESS=
